# ═══════════════════════════════════════════════════════════
# AI Companion — Environment Variables Template
# Copy to .env and fill in values
# ═══════════════════════════════════════════════════════════

# ── Environment ──────────────────────────────────────────
AI_COMPANION_ENV=dev                          # dev | production

# ── LLM Inference ────────────────────────────────────────
LLM_BASE_URL=https://your-runpod-endpoint/v1
LLM_API_KEY=your-api-key
LLM_MODEL=google/gemma-3-4b-it

# ── Database (PostgreSQL) ────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/ai_companion

# ── Cache & Session (Redis) ──────────────────────────────
REDIS_URL=redis://default:password@host:6379

# ── Auth (JWT) ───────────────────────────────────────────
JWT_SECRET_KEY=change-this-to-a-random-64-char-string

# ── CORS (comma-separated origins) ──────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
